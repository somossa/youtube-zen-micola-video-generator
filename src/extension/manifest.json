{
  "manifest_version": 3,
  "name": "Higgsfield AI Controller",
  "version": "1.0.0",
  "description": "Automates higgsfield.ai image generation via WebSocket commands",
  "permissions": ["activeTab"],
  "host_permissions": ["https://*.higgsfield.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.higgsfield.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Higgsfield AI Controller",
    "default_popup": "popup.html"
  }
}
